<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agent-constitution.mcp</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/su6i/@-github/agent-constitution/bin/mcp-server/server_http.py</string>
        <string>--port</string>
