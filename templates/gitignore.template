# ─── Agent Constitution · Standard .gitignore ──────────────────────────────
# Curated for 2026: Python (uv), common editors, OS cruft, project data.
# Source of truth: agent-constitution/templates/gitignore.template
#
# IMPORTANT: this file intentionally does NOT use the bare `lib/`, `bin/`,
# `include/`, `scripts/`, `[Ll]ib`, `[Bb]in` patterns found in generic
# (toptal/github) templates — those silently hide real source folders.
# Ignore virtual-env directories by their actual names instead (.venv, venv).

# ── Project data ────────────────────────────────────────────────────────────
# Policy: persistent runtime data/artifacts live OUTSIDE the repo, in
# ~/.<project>/ . A local .storage/ is a scratch area and must never be
# committed (it may hold large binaries, datasets, models).
.storage/
*.sqlite3
*.db

# ── Secrets & local config ──────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local
config.local.yaml
config.local.yml

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/
MANIFEST

# ── Virtual environments (uv / venv) ────────────────────────────────────────
# NOTE: .python-version is committed on purpose — uv uses it to pin the
# interpreter. Do not ignore it.
.venv/
venv/
ENV/
env.bak/
venv.bak/

# ── Test / coverage / type caches ───────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/

# ── Notebooks ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── Editors / IDEs ──────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ── OS cruft · macOS ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Icon
*.icloud
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ── OS cruft · Linux ────────────────────────────────────────────────────────
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ── OS cruft · Windows ──────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# ── Logs & temp ─────────────────────────────────────────────────────────────
*.log
tmp/
temp/
