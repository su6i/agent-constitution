#!/bin/bash
# ─── Agent Constitution · pre-commit gate ───────────────────────────────────
# Canonical source: agent-constitution/templates/hooks/pre-commit
# Installed into .git/hooks/pre-commit (this repo + every `amir init-project`).
#
# Enforces four NON-NEGOTIABLE constitution rules deterministically, so they
# cannot be "forgotten" by any agent or human:
#
#   1. No direct commits to main/master — use a feature branch.
#   2. Pre-Commit Docs Checklist — a commit that changes code MUST also update
#      documentation (README / CHANGELOG / docs/ / any *.md). A minor change
#      that is really a continuation of the previous commit must be folded in
#      with `git commit --amend`, not landed as a new doc-less commit.
#      Exception: commits that ONLY delete files do not require a doc update
#      (deletions cannot introduce new behaviour that needs documenting).
#   3. Personal/memory workspace files (TODO.md, SESSION.md, TASKS.md,
#      ROADMAP.md, CLAUDE.md, *.session.md, *.local.md) must never reach a
#      commit, even if force-added with `git add -f` past .gitignore.
#      (CLAUDE.md may contain project-specific personal configuration that
#      must not enter the shared repo; commit it only via --no-verify if
#      you are intentionally updating the shared template version.)
#   4. Secrets / personal data in newly ADDED lines (keys, tokens, phone
#      numbers, or values from the gitignored personal_data file) block the
#      commit. Reports file + type only — never the matched value.
#   5. (Warning, non-blocking) Untracked throwaway files (scratch*, *_mock.py,
#      *_draft.*, *.tmp, …) are listed as a cleanliness reminder.
#
# Merge commits: git does NOT run pre-commit on merge commits (fast-forward or
# --no-ff). Rules 1–4 are therefore not enforced on merges. Ensure your CI
# pipeline runs equivalent secret-scan and branch-protection checks on PRs so
# merges into main are gated at the server side too.
#
# Deliberate bypass (discouraged, leaves a trace in your shell history):
#     git commit --no-verify
#
# Written for bash 3.2 (macOS default) — no mapfile / associative arrays.

# symbolic-ref reports the real branch name even on an unborn branch (no commits
# yet), where rev-parse --abbrev-ref would return "HEAD" and miss the guard.
branch="$(git symbolic-ref --short -q HEAD 2>/dev/null || git rev-parse --abbrev-ref HEAD 2>/dev/null)"

# ── Rule 1: protect main/master ─────────────────────────────────────────────
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
    echo ""
    echo "🚨 pre-commit: DIRECT COMMITS TO '$branch' ARE FORBIDDEN."
    echo "   Agents and humans must use a feature branch:"
    echo "     git checkout -b feature/your-task-name"
    echo ""
    exit 1
fi

# ── Rule 2: code changes require a documentation change ─────────────────────
# Only Added/Copied/Modified/Renamed files can introduce undocumented behaviour.
# Deletion-only commits do not require a doc update: removing code cannot add
# behaviour that needs to be documented.  We detect this case explicitly so the
# intent is clear rather than relying on an empty `staged` string.
all_staged="$(git diff --cached --name-only)"
staged="$(git diff --cached --name-only --diff-filter=ACMR)"

# If ALL staged changes are deletions (ACMR list is empty but something is staged),
# skip the docs check — deletions are always allowed without a matching doc change.
if [ -z "$staged" ] && [ -n "$all_staged" ]; then
    : # deletion-only commit — skip Rule 2 and proceed to Rules 3-5
elif [ -z "$staged" ]; then
    exit 0  # nothing staged at all — nothing to check
else
    doc=0
    code=0
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        case "$f" in
            *.md|*.MD|docs/*|*/docs/*|CHANGELOG*|README*)
                doc=1 ;;
            *)
                code=1 ;;
        esac
    done <<EOF
$staged
EOF

    if [ "$code" = "1" ] && [ "$doc" = "0" ]; then
        echo ""
        echo "🚨 pre-commit: code changed but NO documentation was updated."
        echo "   The Pre-Commit Docs Checklist is non-negotiable. Update one of:"
        echo "     • README        — if usage / features / structure changed"
        echo "     • CHANGELOG.md   — if the project has one"
        echo "     • docs/**        — if documented behaviour changed"
        echo "   …then re-stage and commit again."
        echo ""
        echo "   If this is a MINOR continuation of the previous commit, amend it"
        echo "   instead of creating a new commit:"
        echo "     git commit --amend"
        echo ""
        exit 1
    fi
fi

# ── Rule 3: block personal/memory workspace files ──────────────────────────
# TODO/SESSION/TASKS/ROADMAP and *.session/*.local are always personal → blocked
# by name. CLAUDE.md is blocked ONLY when it is gitignored — i.e. a force-added
# personal CLAUDE.md (with user context/local paths). A repo's own *tracked*
# CLAUDE.md (the shared template, a project's intentional agent doc) is allowed.
blocked=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    base="$(basename "$f")"
    case "$base" in
        TODO.md|SESSION.md|TASKS.md|ROADMAP.md|*.session.md|*.local.md)
            echo "🚨 pre-commit: '$f' is a personal/memory workspace file and must never be committed."
            blocked=1
            ;;
        CLAUDE.md)
            if git check-ignore -q "$f" 2>/dev/null; then
                echo "🚨 pre-commit: '$f' is gitignored (personal CLAUDE.md) and was force-added — must not be committed."
                blocked=1
            fi
            ;;
    esac
done <<EOF
$all_staged
EOF

if [ "$blocked" = "1" ]; then
    echo ""
    echo "   Unstage it and confirm it is listed in .gitignore:"
    echo "     git restore --staged <file>"
    echo ""
    exit 1
fi

# ── Rule 4: block secrets / personal data in newly ADDED content ────────────
# Scans only the lines this commit adds (never re-flags data already in
# history). The personal denylist is sourced from the gitignored personal_data
# file, so no personal value is stored in this hook. Reports FILE + TYPE only —
# never the matched value (printing it would re-leak it; see rules/040-git.md
# "Commit Message Privacy").
scan_files=""
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        *.example.*|.env.example|master_cv.example.json) continue ;;
        *.png|*.jpg|*.jpeg|*.gif|*.pdf|*.gz|*.zip|*.xlsx|*.docx|*.lock) continue ;;
    esac
    scan_files="$scan_files $f"
done <<EOF
$staged
EOF

pii=0
if [ -n "$scan_files" ]; then
    added="$(git diff --cached --diff-filter=ACMR -U0 -- $scan_files 2>/dev/null \
             | grep '^+' | grep -v '^+++' | sed 's/^+//')"

    flag() { echo "🚨 pre-commit: possible $1 in staged additions (value hidden)."; pii=1; }

    printf '%s\n' "$added" | grep -qE 'BEGIN [A-Z ]*PRIVATE KEY'  && flag "private key"
    printf '%s\n' "$added" | grep -qE 'AKIA[0-9A-Z]{16}'          && flag "AWS access key"
    printf '%s\n' "$added" | grep -qE '(gh[posru]_[A-Za-z0-9]{30,}|github_pat_[A-Za-z0-9_]{30,})' && flag "GitHub token"
    printf '%s\n' "$added" | grep -qE 'xox[baprs]-[A-Za-z0-9-]{10,}' && flag "Slack token"
    printf '%s\n' "$added" | grep -qE 'sk-[A-Za-z0-9]{20,}'       && flag "API secret key"
    printf '%s\n' "$added" | grep -qE '(^|[^A-Za-z0-9+])(\+33[ .]?|0033[ .]?|0)[1-9]([ .]?[0-9]{2}){4}([^0-9]|$)' && flag "phone number"

    # Real email addresses (allow common placeholders).
    emails="$(printf '%s\n' "$added" \
        | grep -oiE '[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}' \
        | grep -ivE 'example\.(com|org|net)|@example|noreply|no-reply|your-?(email|name)|user@host|@test')"
    [ -n "$emails" ] && flag "email address"

    # Personal denylist from the gitignored personal_data file (identity fields only).
    pd=""
    for c in templates/shared/personal_data.tex templates/shared/personal_data.json; do
        [ -f "$c" ] && pd="$c" && break
    done
    if [ -n "$pd" ] && [ -n "$added" ]; then
        vals="$(grep -oE '\\(cvname|cvfirstname|cvlastname|cvemail|cvphone|cvlinkedin)\}\{[^}]+\}' "$pd" 2>/dev/null | sed -E 's/.*\}\{//; s/\}$//')
$(grep -oiE '"(name|firstname|lastname|email|phone|tel|mobile)"[[:space:]]*:[[:space:]]*"[^"]+"' "$pd" 2>/dev/null | sed -E 's/.*:[[:space:]]*"//; s/"$//')"
        while IFS= read -r v; do
            [ -z "$v" ] && continue
            [ "${#v}" -lt 4 ] && continue
            case "$v" in http*|www.*) continue ;; esac
            if printf '%s\n' "$added" | grep -Fq "$v"; then
                flag "personal data (matches personal_data file)"
                break
            fi
        done <<PD
$vals
PD
    fi
fi

if [ "$pii" = "1" ]; then
    echo ""
    echo "   Remove the sensitive value or unstage the file. If this is genuinely"
    echo "   a false positive, bypass once (leaves a shell-history trace):"
    echo "     git commit --no-verify"
    echo ""
    exit 1
fi

# ── Rule 5: warn (non-blocking) about untracked throwaway files ─────────────
# Agent scratch files left in the tree clutter `git status`. This is a nudge,
# not a block — untracked files are never committed anyway (see 040-git.md
# "Before Commit" step 5).
junk="$(git ls-files --others --exclude-standard 2>/dev/null \
        | grep -iE '(^|/)(scratch|tmp_|debug_|run_mock)|_(draft|mock|tmp|scratch)\.|\.tmp$|_test\.(py|tex)$')"
if [ -n "$junk" ]; then
    echo ""
    echo "🧹 pre-commit (reminder, not blocking): untracked throwaway files present:"
    printf '%s\n' "$junk" | head -20 | sed 's/^/     /'
    echo "   Remove them or add to .gitignore before they pile up."
    echo ""
fi

exit 0
