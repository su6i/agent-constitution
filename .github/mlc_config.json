{
  "ignorePatterns": [
    {
      "pattern": "^https://img.shields.io"
    },
    {
      "pattern": "^https://linkedin.com"
    },
    {
      "pattern": "^#"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^.cursor/",
      "replacement": "{{BASEURL}}/.cursor/"
    }
  ],
  "httpHeaders": [
    {
      "urls": ["https://github.com"],
      "headers": {
        "Accept-Encoding": "zstd, br, gzip, deflate"
      }
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 5,
  "aliveStatusCodes": [200, 206, 301, 302, 307, 308]
}
